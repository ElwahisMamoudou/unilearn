# ─────────────────────────────────────────────────
# Configuration UniLearn Backend — copiez ce fichier
# en ".env" et renseignez vos valeurs
# ─────────────────────────────────────────────────

# ── Sécurité JWT ──────────────────────────────────
# Changez cette clé en production !
SECRET_KEY=unilearn-super-secret-key-change-in-production

# ── Email SMTP ────────────────────────────────────
# Laissez vide pour désactiver l'envoi d'emails
# (les mots de passe seront quand même visibles dans la réponse API)

# Exemple avec Gmail :
#   1. Activez la validation en 2 étapes sur votre compte Google
#   2. Créez un "Mot de passe d'application" sur myaccount.google.com/apppasswords
#   3. Utilisez ce mot de passe dans SMTP_PASSWORD (pas votre mot de passe Gmail habituel)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre-app-password-gmail
SMTP_FROM=UniLearn <votre-email@gmail.com>

# Exemple avec un serveur SMTP université :
# SMTP_HOST=smtp.univ-ngaoundere.cm
# SMTP_PORT=587
# SMTP_USER=noreply@univ-ngaoundere.cm
# SMTP_PASSWORD=motdepasse
# SMTP_FROM=UniLearn <noreply@univ-ngaoundere.cm>

# ── URL Frontend ──────────────────────────────────
# Utilisée dans les emails (bouton "Se connecter")
FRONTEND_URL=http://localhost:5173
