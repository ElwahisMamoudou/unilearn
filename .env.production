# Production environment variables for Vite builds.
#
# NOTE: Vercel does NOT automatically load this file. You must also add
# VITE_API_URL to your Vercel project under Settings > Environment Variables
# so it is injected at build time. This file serves as documentation and as
# a fallback for other build environments (e.g. CI, Docker).
#
# The fallback in src/api/client.js also hardcodes this URL as a last resort.
VITE_API_URL=https://web-production-0a022.up.railway.app/api
